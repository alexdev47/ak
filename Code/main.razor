@using Sandbox;
@using Sandbox.UI;
@using System;
@using System.Linq;
@using System.Collections.Generic;
@using System.Threading.Tasks;
@inherits PanelComponent

<style>
    .game-root {
        width: 100%;
        height: 100%;
        display: flex;
        flex-direction: row;
        font-family: sans-serif;
        color: white;
        background-color: #1a1a1a;
        pointer-events: all;
    }

    .sidebar {
        width: 30%;
        min-width: 350px;
        max-width: 450px;
        background-color: rgba(40, 40, 40, 0.95);
        border-right: 2px solid #555;
        padding: 20px;
        display: flex;
        flex-direction: column;
        gap: 25px;
        z-index: 5;
        overflow-y: auto;
    }

    .stats-row {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 15px;
        font-size: 32px;
        font-weight: bold;
    }

    .money-icon {
        width: 48px;
        height: 48px;
        object-fit: contain;
    }

    .shop-container, .upgrades-container {
        border: 2px solid #555;
        border-radius: 8px;
        padding: 15px;
        display: flex;
        flex-direction: column;
        gap: 15px;
        background-color: rgba(20, 20, 20, 0.5);
        flex-shrink: 0;
    }

    .shop-title {
        text-align: center;
        font-size: 22px;
        font-weight: bold;
        text-transform: uppercase;
        border-bottom: 2px solid #444;
        padding-bottom: 10px;
        margin-bottom: 5px;
    }

    .shop-list {
        display: flex;
        flex-direction: column;
        gap: 10px;
    }

    .shop-item {
        display: flex;
        align-items: center;
        justify-content: space-between;
        border: 2px solid #444;
        border-radius: 6px;
        padding: 12px;
        background-color: rgba(60, 60, 60, 0.8);
        gap: 10px;
    }

    .item-info {
        display: flex;
        flex-direction: column;
        flex-grow: 1;
        padding-right: 15px;
    }

    .item-title {
        font-size: 18px;
        font-weight: bold;
    }

    .item-desc {
        font-size: 14px;
        color: #ccc;
        margin-top: 6px;
        white-space: normal;
    }

    .buy-btn, .click-btn {
        background-image: url('/ui/button.png');
        background-size: 100% 100%;
        background-position: center;
        background-repeat: no-repeat;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: transform 0.05s ease-in-out;
        font-weight: bold;
        text-shadow: 1px 1px 2px rgba(0,0,0,0.8);
        flex-shrink: 0;
    }

    .click-btn {
        width: 100%;
        height: 60px;
        font-size: 24px;
    }

    .buy-btn {
        width: 110px;
        height: 55px;
        font-size: 20px;
    }

        .buy-btn:active, .click-btn:active {
            transform: scale(0.95);
        }

        .buy-btn.disabled {
            filter: grayscale(100%);
            opacity: 0.5;
            pointer-events: none;
        }

    .main-area {
        flex-grow: 1;
        position: relative;
        background-image: url('/ui/background.png');
        background-repeat: repeat;
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
    }

    .no-ticket-text {
        font-size: 32px;
        color: rgba(255,255,255,0.3);
        font-weight: 900;
        text-transform: uppercase;
        border: 4px dashed rgba(255,255,255,0.2);
        padding: 30px 60px;
        border-radius: 16px;
    }

    .table-ticket {
        position: absolute;
        background-size: 100% 100%;
        cursor: pointer;
        transition: transform 0.2s, filter 0.2s;
        box-shadow: 0 5px 15px rgba(0,0,0,0.6);
        display: flex;
        justify-content: center;
    }

        .table-ticket:hover {
            filter: brightness(1.2);
            z-index: 10 !important;
        }

    .right-sidebar {
        width: 25%;
        min-width: 250px;
        max-width: 350px;
        background-color: rgba(40, 40, 40, 0.95);
        border-left: 2px solid #555;
        padding: 20px;
        display: flex;
        flex-direction: column;
        gap: 20px;
        z-index: 5;
    }

    .history-log {
        display: flex;
        flex-direction: column;
        gap: 8px;
        font-size: 16px;
        font-weight: bold;
        overflow-y: auto;
    }

    .history-win {
        color: #4CAF50;
    }

    .history-loss {
        color: #f44336;
    }

    .history-buy {
        color: #ff9800;
    }

    .modal-overlay {
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background-color: rgba(0,0,0,0.85);
        z-index: 100;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .modal-content {
        display: flex;
        flex-direction: row;
        gap: 40px;
        align-items: center;
    }

    .ticket-legend {
        background-color: #222;
        padding: 30px;
        border-radius: 16px;
        border: 2px solid #555;
        max-width: 300px;
        color: #eee;
        display: flex;
        flex-direction: column;
        gap: 15px;
        box-shadow: 0 0 20px rgba(0,0,0,0.8);
        position: relative;
        z-index: 110;
    }

    .legend-title {
        font-size: 24px;
        font-weight: 900;
        color: #ff9800;
        text-align: center;
        margin-bottom: 10px;
    }

    .legend-desc {
        font-size: 16px;
        margin-bottom: 15px;
    }

    .legend-item {
        display: flex;
        align-items: center;
        gap: 12px;
        font-size: 15px;
        font-weight: bold;
    }

        .legend-item img {
            width: 32px;
            height: 32px;
            object-fit: fill;
        }

    .close-btn {
        margin-top: 20px;
        background-color: #f44336;
        border-radius: 8px;
        color: white;
        text-align: center;
        font-weight: bold;
        font-size: 18px;
        padding: 12px;
        cursor: pointer;
        transition: transform 0.05s;
    }

        .close-btn:active {
            transform: scale(0.95);
        }
</style>

<root class="game-root">

    <div class="sidebar">

        <div class="stats-row">
            <img class="money-icon" src="/ui/coin.png" alt="Money" />
            <div class="money-counter">$ @Money.ToString("0.00")</div>
        </div>

        <div class="click-btn" onclick=@(() => EarnMoney())>
            CLICK
        </div>

        <div class="shop-container">
            <div class="shop-title">SHOP</div>

            <div class="shop-list">
                <div class="shop-item">
                    <div class="item-info">
                        <div class="item-title">ONE LUCKY TICKET</div>
                        <div class="item-desc">Basic ticket just for fun</div>
                    </div>
                    <div class="buy-btn @(Money < BasicTicketCost ? "disabled" : "")"
                         onclick=@(() => BuyTicket(BasicTicketCost, "БРОНЗА", 20m, 0.4f))>
                        $ @BasicTicketCost.ToString("0")
                    </div>
                </div>

                <div class="shop-item">
                    <div class="item-info">
                        <div class="item-title">TICKET 67</div>
                        <div class="item-desc">Brainrot edition, funded by tun tun sahur </div>
                    </div>
                    <div class="buy-btn @(Money < 10m ? "disabled" : "")"
                         onclick=@(() => BuyTicket(10m, "СРІБЛО", 200m, 0.3f))>
                        $ 10
                    </div>
                </div>

                <div class="shop-item">
                    <div class="item-info">
                        <div class="item-title">GAMBLERS PARADISE</div>
                        <div class="item-desc">ALL OT NOTHING!!!!</div>
                    </div>
                    <div class="buy-btn @(Money < 50m ? "disabled" : "")"
                         onclick=@(() => BuyTicket(50m, "ЗОЛОТО", 1000m, 0.2f))>
                        $ 50
                    </div>
                </div>
            </div>
        </div>

        <div class="upgrades-container">
            <div class="shop-title">Upgrades</div>

            <div class="shop-list">
                <div class="shop-item">
                    <div class="item-info">
                        <div class="item-title">Income</div>
                        <div class="item-desc">x2 reward from clicks</div>
                    </div>
                    <div class="buy-btn @(Money < 15m ? "disabled" : "")"
                         onclick=@(() => BuyUpgrade("Income", 15m))>
                        $ 15
                    </div>
                </div>

                <div class="shop-item">
                    <div class="item-info">
                        <div class="item-title">Autoclicker</div>
                        <div class="item-desc">-10% time between autoclicks</div>
                    </div>
                    <div class="buy-btn @(Money < 30m ? "disabled" : "")"
                         onclick=@(() => BuyUpgrade("Autoclicker", 30m))>
                        $ 30
                    </div>
                </div>

                <div class="shop-item">
                    <div class="item-info">
                        <div class="item-title">VIP</div>
                        <div class="item-desc">VIP ticket</div>
                    </div>
                    <div class="buy-btn @(Money < 100m ? "disabled" : "")"
                         onclick=@(() => BuyUpgrade("VIP", 100m))>
                        $ 100
                    </div>
                </div>
            </div>
        </div>

    </div>

    <div class="main-area">
        @foreach (var ticket in TicketsOnTable)
        {
            <div class="table-ticket"
                 style="width: @(ticket.Width)px; height: @(ticket.Height)px; background-image: url('@GetTicketImage(ticket.Tier)'); left: @(ticket.X)px; top: @(ticket.Y)px; transform: rotate(@(ticket.Rotation)deg) translate(-50%, -50%); z-index: @(ticket.ZIndex);"
                 onclick=@(() => OpenTicket(ticket))>
            </div>
        }

        @if (OpenedTicket != null)
        {
            <div class="modal-overlay">
                <div class="modal-content">

                    <div class="ticket-legend">
                        <div class="legend-title">RULES</div>
                        <div class="legend-desc">Get 3 same pictures, to hit a jackpot!</div>

                        <div style="display:flex; flex-direction:column; gap:10px;">
                            <div class="legend-item"><img src="/ui/tickets/symbols/chest.png" /> <span>~25%</span></div>
                            <div class="legend-item"><img src="/ui/tickets/symbols/energy.png" /> <span>~25%</span></div>
                            <div class="legend-item"><img src="/ui/tickets/symbols/message.png" /> <span>~15%</span></div>
                            <div class="legend-item"><img src="/ui/tickets/symbols/skull.png" /> <span>~15%</span></div>
                            <div class="legend-item"><img src="/ui/tickets/symbols/gift.png" /> <span>~10%</span></div>
                            <div class="legend-item"><img src="/ui/tickets/symbols/Action!.png" /> <span>~5%</span></div>
                            <div class="legend-item"><img src="/ui/tickets/symbols/lottery circle.png" /> <span>~5%</span></div>
                        </div>

                        <div class="close-btn" onclick=@CloseTicket>CLOSE</div>
                    </div>

                    <ScratchTicket PrizeAmount="@OpenedTicket.Prize"
                                   TicketTier="@OpenedTicket.Tier"
                                   OnComplete="@(new Action<decimal>(OnTicketScratched))" />
                </div>
            </div>
        }
        else if (TicketsOnTable.Count == 0)
        {
            <div class="no-ticket-text">Buy a Ticket</div>
        }
    </div>

    <div class="right-sidebar">

        <div class="shop-container" style="flex-grow: 1; display: flex; flex-direction: column; overflow: hidden;">
            <div class="shop-title">Leaderboard</div>
            <div class="history-log" style="padding-right: 5px;">
                <div style="display: flex; justify-content: space-between; font-weight: bold; align-items: center; padding: 5px 0;">
                    <span style="color: #ff9800; font-size: 18px;">1. PlayerOne</span>
                    <span class="history-win" style="font-size: 18px;">$ 999.00</span>
                </div>
                <div style="display: flex; justify-content: space-between; font-weight: bold; align-items: center; padding: 5px 0;">
                    <span style="color: #ccc; font-size: 16px;">2. Facepuncher</span>
                    <span class="history-win" style="font-size: 16px;">$ 500.00</span>
                </div>
                <div style="display: flex; justify-content: space-between; font-weight: bold; align-items: center; padding: 5px 0;">
                    <span style="color: #cd7f32; font-size: 16px;">3. DevMaster</span>
                    <span class="history-win" style="font-size: 16px;">$ 152.00</span>
                </div>
                <div style="display: flex; justify-content: space-between; font-weight: bold; align-items: center; padding: 5px 0;">
                    <span style="color: #888;">4. Garry</span>
                    <span class="history-win" style="color: #888;">$ 50.00</span>
                </div>
                <div style="display: flex; justify-content: space-between; font-weight: bold; align-items: center; padding: 5px 0;">
                    <span style="color: #888;">5. You</span>
                    <span class="history-win" style="color: #888;">$ @Money.ToString("0.00")</span>
                </div>
            </div>
        </div>

        <div class="shop-container" style="flex-grow: 1; display: flex; flex-direction: column; overflow: hidden; margin-bottom: 0;">
            <div class="shop-title">History</div>
            <div class="history-log" style="padding-right: 5px;">
                @foreach (var log in TicketHistory.AsEnumerable().Reverse().Take(15))
                {
                    <div class="@(log.Amount > 0 ? "history-win" : (log.Amount < 0 ? "history-buy" : "history-loss"))">
                        @log.Message
                    </div>
                }
            </div>
        </div>
    </div>

</root>

@code
{
    public class ActiveTicket
    {
        public Guid Id { get; set; } = Guid.NewGuid();
        public float X { get; set; }
        public float Y { get; set; }
        public float Rotation { get; set; }
        public int ZIndex { get; set; }
        public decimal Prize { get; set; } // Оновлено до decimal
        public string Tier { get; set; }
        public float Width { get; set; }
        public float Height { get; set; }
    }

    public class HistoryEntry
    {
        public string Message { get; set; }
        public decimal Amount { get; set; } // Оновлено до decimal
    }

    // Оновлено стартовий баланс на 1$ (можеш змінити на 0m, якщо треба)
    [Property] public decimal Money { get; set; } = 1.00m;

    public decimal BasicTicketCost = 1m; // 1$
    public List<ActiveTicket> TicketsOnTable { get; set; } = new();
    public ActiveTicket OpenedTicket { get; set; }
    public List<HistoryEntry> TicketHistory { get; set; } = new();
    private int ticketZCounter = 1;

    public string GetTicketImage(string tier)
    {
        if (tier == "СРІБЛО") return "/ui/tickets/2.png";
        if (tier == "ЗОЛОТО") return "/ui/tickets/3.png";
        return "/ui/tickets/1.png";
    }

    public void EarnMoney()
    {
        Money += 0.01m; // За 1 клік дає 0.01$
    }

    public void BuyTicket(decimal cost, string tier, decimal maxPrize, float winChance)
    {
        if (Money >= cost)
        {
            Money -= cost;

            bool isWin = System.Random.Shared.NextSingle() <= winChance;
            decimal prize = 0m;

            if (isWin)
            {
                // Генеруємо випадковий дробовий приз від подвійної ціни до maxPrize
                double min = (double)(cost * 2m);
                double max = (double)maxPrize;
                double range = max - min;
                double sample = System.Random.Shared.NextDouble();
                double scaled = (sample * range) + min;
                prize = Math.Round((decimal)scaled, 2); // Округлюємо до 2 знаків
            }

            ticketZCounter++;

            float tx = 150 + System.Random.Shared.Next(0, 300);
            float ty = 150 + System.Random.Shared.Next(0, 300);
            float trot = System.Random.Shared.Next(-35, 35);

            float tableW = 152f;
            float tableH = 208f;

            if (tier == "СРІБЛО")
            {
                tableW = 208f;
                tableH = 152;
            }
            if (tier == "ЗОЛОТО")
            {
                tableW = 250f;
                tableH = 120f;
            }

            TicketsOnTable.Add(new ActiveTicket
            {
                Prize = prize,
                Tier = tier,
                X = tx,
                Y = ty,
                Rotation = trot,
                ZIndex = ticketZCounter,
                Width = tableW,
                Height = tableH
            });
        }
    }

    public void BuyUpgrade(string upgradeName, decimal cost)
    {
        if (Money >= cost)
        {
            Money -= cost;

            TicketHistory.Add(new HistoryEntry
            {
                Amount = -cost,
                Message = $"Bought: {upgradeName} (-${cost.ToString("0.00")})"
            });
        }
    }

    public void OpenTicket(ActiveTicket ticket)
    {
        ticketZCounter++;
        ticket.ZIndex = ticketZCounter;
        OpenedTicket = ticket;
    }

    public void CloseTicket()
    {
        OpenedTicket = null;
        StateHasChanged();
    }

    public void OnTicketScratched(decimal winAmount)
    {
        Money += winAmount;

        TicketHistory.Add(new HistoryEntry
        {
            Amount = winAmount,
            Message = winAmount > 0 ? $"Win: ${winAmount.ToString("0.00")}" : "You lost..."
        });

        _ = DestroyTicketAfterDelay();
    }

    private async Task DestroyTicketAfterDelay()
    {
        try
        {
            await GameTask.DelaySeconds(2.0f);
            if (!IsValid) return;

            if (OpenedTicket != null)
            {
                TicketsOnTable.Remove(OpenedTicket);
                OpenedTicket = null;
            }
            StateHasChanged();
        }
        catch (System.Exception)
        {
        }
    }

    protected override int BuildHash() => System.HashCode.Combine(Money, TicketsOnTable.Count, OpenedTicket != null, TicketHistory.Count);
}
